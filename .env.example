# Copy to .env — do not commit .env

NODE_ENV=development
PORT=3001

# Database (use DB_* or MYSQL_* — DB_* takes priority)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=your_database_name

# AWS RDS: SSL is auto-enabled for *.rds.amazonaws.com hosts
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Admin CMS login (username + password on /admin/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Signs session tokens after login (use a long random string)
JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars

# Optional: legacy API key for scripts (X-Admin-Key header)
ADMIN_API_KEY=

AI_POLLINATIONS_URL=https://text.pollinations.ai/
